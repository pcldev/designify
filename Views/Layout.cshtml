@{
    ViewData["Title"] = "Home Page";
}
<style>
    .menu {
        margin-bottom: 10px;
    }

    ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: #333;
    }

    .menu-item {
        float: left;
        border-right: 1px solid #bbb;
    }

    .menu-item:last-child {
        border-right: none;
    }

    .menu-item a {
        display: block;
        color: white;
        text-align: center;
        padding: 14px 16px;
        text-decoration: none;
    }

    .menu-item a:hover:not(.active) {
        background-color: #111;
    }

    .menu-active {
        background-color: #fb99f4;
    }
</style>
