<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <title>@ViewData["Title"]</title>
    <style>
        .wrapper {
            padding: 10px;
        }

        #canvasList {
            margin-top: 20px;
            display: flex;
            flex-wrap: wrap;
            list-style: none;
            padding-left: 0;
            gap: 10px;
        }

        .canvas-item {
            width: 30%;
            margin: 0 auto;
            outline: 1px solid;
            overflow-x: scroll;
            border: 1px solid #ccc;
            padding: 5px 10px;
        }

        @@media only screen and (max-width: 600px) {
            .canvas-item {
                width: 100%;
            }
        }


        .canvas-item span {
            display: block;
            text-align: center;
            font-weight: bold;
            width: 100%;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .canvas-list {
            display: flex;
            flex-wrap: wrap;
        }
    </style>


</head>

<body>
    @* menu here *@
@*     <div>
        <label for="canva-timkiem">Tìm kiếm</label>
        <input type="text" id="canva_timkiem-input" value="default key" />
    </div> *@
    <div class="wrapper">
        <button id="createcanvasbtn">Create new Canva</button>
        <div id="canvasList" class="canvas-list"></div>
    </div>

    <script>
        document.getElementById("createcanvasbtn").addEventListener("click", function () {
            // Tạo một unique id
            var uniqueId = Date.now().toString();

            // Mở một tab mới với đường dẫn tương ứng
            var url = "/canva/" + uniqueId;
            window.open(url, "_blank");
        });

        document.addEventListener("DOMContentLoaded", function () {
            // Load danh sách canvas khi trang được tải
            loadCanvasList();
        });

        async function loadCanvasList() {
            // Danh sách canvas đã được khai báo ở trên
            const response = await fetch('/Home/GetAllCanvas')
            const data = await response.json()

            displayCanvasList(data);
        }

        function displayCanvasList(canvasList) {
            var canvasListContainer = document.getElementById("canvasList");
            canvasListContainer.innerHTML = ""; // Xóa nội dung cũ
            canvasList.forEach(function (canvas) {
                var canvasItem = document.createElement("div");
                canvasItem.classList.add("canvas-item");

                Object.keys(canvas).forEach(canvasKey => {
                    const li = document.createElement('li')
                    li.textContent = `${canvasKey}: ${canvas[canvasKey]}`

                    canvasItem.appendChild(li)
                })

                // Đặt sự kiện click để chuyển hướng khi nhấp vào canvas
                canvasItem.addEventListener("click", function () {
                    window.location.href = "/canva/" + canvas.idCanvas;
                });

                // Thêm ảnh xem trước và tên canvas vào phần tử canvasItem
        @* canvasItem.appendChild(canvasName); *@
        @* canvasItem.appendChild(canvasUpdated); *@

                    // Thêm phần tử canvasItem vào danh sách
                    canvasListContainer.appendChild(canvasItem);
            });
        }
    </script>
    <script>

        const id_user = window.location.search.split("user=")[1]

        id_user && localStorage.setItem('id_user', id_user)

    </script>
</body>

</html>